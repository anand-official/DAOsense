# ===== DAOSense Environment Variables =====

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Avalanche
FUJI_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
MAINNET_RPC_URL=https://api.avax.network/ext/bc/C/rpc
DEPLOYER_PRIVATE_KEY=your-deployer-wallet-private-key
NEXT_PUBLIC_VERIFIER_CONTRACT_ADDRESS=0x_deployed_contract_address

# Vercel Cron Secret
CRON_SECRET=your-cron-secret-string

# Snapshot
SNAPSHOT_GRAPHQL_URL=https://hub.snapshot.org/graphql
SNAPSHOT_SPACES=traderjoe-xyz,benqi-finance,pangolin-exchange
